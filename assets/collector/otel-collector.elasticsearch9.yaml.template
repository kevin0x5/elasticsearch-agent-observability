receivers:
  otlp:
    protocols:
      grpc:
      http:

processors:
  memory_limiter:
    check_interval: 1s
    limit_mib: 512
  batch:
    send_batch_size: 1024
    timeout: 5s
  resource/runtime:
    attributes:
      - key: service.name
        value: "${SERVICE_NAME}"
        action: upsert
      - key: deployment.environment
        value: "${ENVIRONMENT}"
        action: upsert
      - key: agent.discovery.modules
        value: "${MODULES}"
        action: upsert
      - key: observer.product
        value: elasticsearch-agent-observability
        action: upsert
  attributes/redact:
    actions:
      - key: gen_ai.prompt
        action: delete
      - key: gen_ai.tool.call.arguments
        action: delete
      - key: gen_ai.tool.call.result
        action: delete

exporters:
  elasticsearch:
    endpoints: ["${ES_URL}"]
    # user: "${env:ELASTICSEARCH_USERNAME}"
    # password: "${env:ELASTICSEARCH_PASSWORD}"
    logs_index: "${INDEX_PREFIX}-events"
    traces_index: "${INDEX_PREFIX}-events"

service:
  pipelines:
    traces:
      receivers: [otlp]
      processors: [memory_limiter, resource/runtime, attributes/redact, batch]
      exporters: [elasticsearch]
    logs:
      receivers: [otlp]
      processors: [memory_limiter, resource/runtime, attributes/redact, batch]
      exporters: [elasticsearch]
